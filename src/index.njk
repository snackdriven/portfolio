---
layout: base.njk
title: "snackdriven — off the happy path"
description: "Field notes on test automation, internal tooling, and developer experience."
blogcss: true
---
<div class="wrap">
  {% include "topbar.njk" %}
  <h1 class="neon post-title">off the happy path</h1>
  <p class="page-intro">Notes on test automation, internal tooling, and developer experience &mdash; written mostly so future me remembers why past me did the thing.</p>
  <ul class="posts">
    {% for post in collections.post | reverse %}
    {% if not post.data.hidden %}
    <li>
      <a class="post-row" href="{{ post.url }}">
        <div class="post-meta">
          <span>{{ post.date | ymd }}</span>
          <span class="tag">#{{ post.data.tag }}</span>
          {% if post.data.badge %}<span class="badge">{{ post.data.badge }}</span>{% endif %}
        </div>
        <h2>{{ post.data.title }}</h2>
        <p>{{ post.data.excerpt }}</p>
      </a>
    </li>
    {% endif %}
    {% endfor %}
  </ul>
  {% include "site-footer.njk" %}
</div>
<script>
(function () {
  var n = document.querySelectorAll('.post-row').length;
  console.log('%c  STATUS  snackdriven.com  ', 'background:#A78BFA;color:#2D2B3A;font-family:"DM Mono",monospace;font-size:11px;font-weight:700;padding:2px 6px;border-radius:2px;');
  console.log('%c\n  ✓  log is alive\n  ✓  ' + n + (n === 1 ? ' post' : ' posts') + ' rendered\n  ✗  more posts pending\n', 'color:#4AEEA0;font-family:"DM Mono",monospace;font-size:11px;line-height:1.9;');
  console.log('%c  ' + n + ' passing  1 pending', 'color:#B5B2C8;font-family:"DM Mono",monospace;font-size:11px;');
})();
</script>
