---
layout: base.njk
title: "snackdriven — off the happy path"
description: "Test automation by trade — and the log of every working tool I couldn't leave alone."
blogcss: true
---
<div class="wrap">
  <h1 class="prompt-title"><span class="host"><span>s</span><span>n</span><span>a</span><span>c</span><span>k</span><span>d</span><span>r</span><span>i</span><span>v</span><span>e</span><span>n</span></span><span class="pmt" aria-hidden="true">:~$</span> <span class="cmd">off the happy path</span><span class="cursor" aria-hidden="true"></span></h1>
  <p class="page-intro">hi, my name is kayla and i can&rsquo;t leave a working tool alone. i break software for a living; the rest is committed, so technically it&rsquo;s research.</p>
  {% if collections.visiblePost.length == 1 %}
  {% set p = collections.visiblePost[0] %}
  <article class="single-post">
    <div class="post-meta">
      <span>{{ p.date | ymd }}</span>
      <span class="tag">#{{ p.data.tag }}</span>
      <span>~{{ p.data.read }} min read</span>
      {% if p.data.badge %}<span class="badge">{{ p.data.badge }}</span>{% endif %}
    </div>
    <h2 class="neon post-title">{{ p.data.title }}</h2>
    {{ p.templateContent | safe }}
  </article>
  {% else %}
  <ul class="posts">
    {% for post in collections.visiblePost %}
    <li>
      <a class="post-row" href="{{ post.url }}">
        <div class="post-meta">
          <span>{{ post.date | ymd }}</span>
          <span class="tag">#{{ post.data.tag }}</span>
          {% if post.data.badge %}<span class="badge">{{ post.data.badge }}</span>{% endif %}
        </div>
        <h2>{{ post.data.title }}</h2>
        <p>{{ post.data.excerpt }}</p>
      </a>
    </li>
    {% endfor %}
  </ul>
  {% endif %}
  {% include "site-footer.njk" %}
</div>
<script>
(function () {
  var n = document.querySelectorAll('.post-row, .single-post').length;
  console.log('%c  STATUS  snackdriven.com  ', 'background:#A78BFA;color:#2D2B3A;font-family:"DM Mono",monospace;font-size:11px;font-weight:700;padding:2px 6px;border-radius:2px;');
  console.log('%c\n  ✓  log is alive\n  ✓  ' + n + (n === 1 ? ' post' : ' posts') + ' rendered\n  ✗  more posts pending\n', 'color:#4AEEA0;font-family:"DM Mono",monospace;font-size:11px;line-height:1.9;');
  console.log('%c  ' + n + ' passing  1 pending', 'color:#B5B2C8;font-family:"DM Mono",monospace;font-size:11px;');
})();

// Neon flicker on the hero name — mirrors the resume's KAYLA YOUNG flicker.
(function () {
  if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
  var letters = Array.from(document.querySelectorAll('.prompt-title .host span'));
  if (!letters.length) return;
  function rnd(a, b) { return Math.floor(Math.random() * (b - a + 1) + a); }
  function flicker(spans, stagger) {
    spans.forEach(function (l, i) {
      setTimeout(function () {
        l.classList.add('flickering');
        setTimeout(function () { l.classList.remove('flickering'); }, 800);
      }, i * (stagger || 0));
    });
  }
  function next() {
    var roll = Math.random();
    if (roll < 0.22) { flicker(letters, 55); setTimeout(next, rnd(3000, 5000)); }            // full-word cascade (rare)
    else if (roll < 0.5) { flicker(letters.slice(rnd(0, 7), rnd(8, 11)), 90); setTimeout(next, rnd(2200, 4000)); } // a run of letters
    else { flicker([letters[rnd(0, letters.length - 1)]], 0); setTimeout(next, rnd(1200, 2800)); } // single letter (common)
  }
  setTimeout(next, 1000);
})();
</script>
