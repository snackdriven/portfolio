---
layout: base.njk
---
<article class="layout">
  <header class="rail rail-post">
    <div class="post-meta">
      <span>{{ date | ymd }}</span>
      <span class="tag">#{{ tag }}</span>
      <span>~{{ read }} min read</span>
      {% if badge %}<span class="badge">{{ badge }}</span>{% endif %}
    </div>
  </header>
  <div class="reading">
    <h1 class="neon post-title">{{ title }}</h1>
    {{ content | safe }}
    <a class="backlink" href="/">&larr; back to the log</a>
  </div>
</article>
