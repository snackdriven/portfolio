---
layout: base.njk
---
<div class="wrap reading">
  {% include "topbar.njk" %}
  <main id="main-content">
  <article>
    <div class="post-meta">
      <span>{{ date | ymd }}</span>
      <span class="tag">#{{ tag }}</span>
      <span>~{{ read }} min read</span>
      {% if badge %}<span class="badge">{{ badge }}</span>{% endif %}
    </div>
    <h1 class="neon post-title">{{ title }}</h1>
    {{ content | safe }}
    <a class="backlink" href="/">&larr; back to the log</a>
  </article>
  </main>
  {% include "site-footer.njk" %}
</div>
